{
    "name": "chubes4/block-format-bridge",
    "type": "wordpress-plugin",
    "description": "WordPress plugin orchestrating bidirectional content format conversion (HTML, Blocks, Markdown) via a unified adapter API.",
    "license": "GPL-2.0-or-later",
    "homepage": "https://github.com/chubes4/block-format-bridge",
    "authors": [
        {
            "name": "Chris Huber",
            "homepage": "https://chubes.net"
        }
    ],
    "scripts": {
        "build": "./build.sh"
    },
    "autoload": {
        "files": [
            "library.php"
        ]
    },
    "require": {
        "automattic/blocks-engine-php-transformer": "dev-draft/php-transformer-monorepo",
        "php": "^8.1",
        "chubes4/html-to-blocks-converter": "dev-main",
        "league/commonmark": "^2.5",
        "league/html-to-markdown": "^5.1"
    },
    "require-dev": {
        "humbug/php-scoper": "^0.18.19"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../blocks-engine@draft-php-transformer-monorepo/php-transformer",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "composer",
            "url": "https://wp-packages.org"
        },
        {
            "type": "vcs",
            "url": "https://github.com/chubes4/html-to-blocks-converter",
            "no-api": true
        }
    ],
    "config": {
        "allow-plugins": {
            "composer/installers": true
        },
        "platform": {
            "php": "8.2.0"
        },
        "sort-packages": true
    }
}
