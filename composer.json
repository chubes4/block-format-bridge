{
    "name": "chubes4/block-format-bridge",
    "type": "wordpress-plugin",
    "description": "WordPress plugin orchestrating bidirectional content format conversion (HTML, Blocks, Markdown) via a unified adapter API.",
    "license": "GPL-2.0-or-later",
    "homepage": "https://github.com/chubes4/block-format-bridge",
    "authors": [
        {
            "name": "Chris Huber",
            "homepage": "https://chubes.net"
        }
    ],
    "scripts": {
        "build": "./build.sh",
        "lint": "php -l block-format-bridge.php && php -l library.php && find includes tests tools -name '*.php' -print0 | xargs -0 -n1 php -l",
        "smokes": "php tests/smoke-content-normalization.php && php tests/smoke-transformer-capability-discovery-standalone.php && php tests/smoke-transformer-capability-discovery-class.php"
    },
    "autoload": {
        "files": [
            "library.php"
        ]
    },
    "require": {
        "php": "^8.1"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        },
        "platform": {
            "php": "8.2.0"
        },
        "sort-packages": true
    }
}
