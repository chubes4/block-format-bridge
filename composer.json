{
    "name": "chubes4/block-format-bridge",
    "type": "wordpress-plugin",
    "description": "WordPress plugin orchestrating bidirectional content format conversion (HTML, Blocks, Markdown) via a unified adapter API.",
    "license": "GPL-2.0-or-later",
    "homepage": "https://github.com/chubes4/block-format-bridge",
    "authors": [
        {
            "name": "Chris Huber",
            "homepage": "https://chubes.net"
        }
    ],
    "scripts": {
        "build": "./build.sh"
    },
    "autoload": {
        "files": [
            "library.php"
        ]
    },
    "require": {
        "automattic/blocks-engine-php-transformer": "dev-trunk",
        "php": "^8.1"
    },
    "require-dev": {
        "humbug/php-scoper": "^0.18.19"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../blocks-engine/php-transformer",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "composer",
            "url": "https://wp-packages.org"
        }
    ],
    "config": {
        "allow-plugins": {
            "composer/installers": true
        },
        "platform": {
            "php": "8.2.0"
        },
        "sort-packages": true
    }
}
